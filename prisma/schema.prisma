generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  todos         Todo[]
  goals         Goal[]
  opportunities Opportunity[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  type      GoalType @default(PERSONAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todos     Todo[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Todo {
  id               String       @id @default(cuid())
  userId           String
  goalId           String?
  opportunityId    String?
  title            String
  notes            String?      @db.Text
  priority         Priority     @default(MEDIUM)
  type             TodoType     @default(PERSONAL)
  status           TodoStatus   @default(PENDING)
  dueDate          DateTime?
  completedAt      DateTime?
  googleTaskId     String?
  googleTaskListId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal             Goal?        @relation(fields: [goalId], references: [id])
  opportunity      Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([userId, dueDate])
  @@index([userId, status])
}

model Opportunity {
  id             String            @id @default(cuid())
  userId         String
  company        String
  role           String
  sourceName     String?
  sourcePlatform SourcePlatform    @default(LINKEDIN)
  sourceUrl      String?
  status         OpportunityStatus @default(DISCOVERED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  notes          OpportunityNote[]
  todos          Todo[]

  @@index([userId, status])
}

model Contact {
  id            String        @id @default(cuid())
  opportunityId String
  name          String
  channel       ContactChannel @default(LINKEDIN)
  status        ContactStatus  @default(NOT_CONTACTED)
  profileUrl    String?
  contactedAt   DateTime?
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  opportunity   Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

model OpportunityNote {
  id            String      @id @default(cuid())
  opportunityId String
  content       String      @db.Text
  createdAt     DateTime    @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TodoType {
  PERSONAL
  PROFESSIONAL
}

enum GoalType {
  PERSONAL
  PROFESSIONAL
}

enum TodoStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum OpportunityStatus {
  DISCOVERED
  OUTREACH_SENT
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  CLOSED
}

enum SourcePlatform {
  LINKEDIN
  REFERRAL
  JOB_BOARD
  OTHER
}

enum ContactChannel {
  LINKEDIN
  EMAIL
  OTHER
}

enum ContactStatus {
  NOT_CONTACTED
  SENT
  REPLIED
  NO_RESPONSE
  REFERRED
}
